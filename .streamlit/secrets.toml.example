# Copy the block you need into Streamlit Community Cloud:
#   App → ⋮ → Settings → Secrets
# (Do not commit real passwords; this file is a template only.)

# --- Option A (recommended): Neon / Postgres connection string ---
# Get this from Neon → Connection details → URI (use the pooler host if you use pooling).
# You can paste the URI with or without ?sslmode=require — the app enables TLS for remote hosts.
# DATABASE_URL = "postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Option B: individual variables ---
# POSTGRES_HOST = "ep-xxxxx.region.aws.neon.tech"
# POSTGRES_PORT = "5432"
# POSTGRES_DB = "neondb"
# POSTGRES_USER = "YOUR_USER"
# POSTGRES_PASSWORD = "YOUR_PASSWORD"
# Optional; the app defaults to require SSL for non-localhost hosts.
# POSTGRES_SSLMODE = "require"

# --- Option C: nested table (also supported) ---
# [postgres]
# host = "ep-xxxxx.region.aws.neon.tech"
# port = "5432"
# database = "neondb"
# user = "YOUR_USER"
# password = "YOUR_PASSWORD"
